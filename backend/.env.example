APP_NAME=Decision Simulation Engine
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql+psycopg://decision:decision@localhost:5432/decision_sim
JWT_SECRET_KEY=change-me-to-a-32-char-secret-at-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
ANALYSIS_CACHE_HOURS=24
REQUEST_TIMEOUT_SECONDS=10
CONNECT_TIMEOUT_SECONDS=5
SCRAPE_MAX_CONTENT_CHARS=15000
SCRAPE_MAX_BYTES=2000000
RATE_LIMIT_PER_MINUTE=60
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
ALLOW_PRIVATE_NETWORK_SCRAPING=false
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=DemoPass123!
